generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  PROFESSIONAL
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum Badge {
  NONE
  BRONZE
  SILVER
  GOLD
  ELITE
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MissionStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  role      UserRole
  status    UserStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile              Profile?
  sessions             Session[]
  clientMissions       Mission[] @relation("ClientMissions")
  proMissions          Mission[] @relation("ProMissions")
  reviews              Review[]
  sentMessages         Message[] @relation("SenderMessages")
  receivedMessages     Message[] @relation("ReceivedMessages")
  savedPros            SavedPro[] @relation("SavedPros")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  firstName     String
  lastName      String
  avatarUrl     String?
  coverUrl      String?
  bio           String?  @db.Text
  profession    String?
  experience    Int?
  zone          String[]
  trustScore    Int      @default(0)
  badge         Badge    @default(NONE)
  isVerified    Boolean  @default(false)
  isOnsiteVerified Boolean @default(false)
  missionCount  Int      @default(0)
  responseTime  Int?
  acceptanceRate Float   @default(0)
  availability  Json?
  isAvailable   Boolean  @default(true)
  onboardingCompleted Boolean @default(false)

  portfolio   PortfolioItem[]
  services    Service[]
  pricing     Pricing[]
  favorites   SavedPro[]
  profileViews ProfileView[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  name      String
  category  String
  createdAt DateTime @default(now())
}

model Pricing {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  service     String
  label       String
  price       Int
  isStartingAt Boolean @default(false)
}

model PortfolioItem {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  type        MediaType @default(IMAGE)
  beforeUrl   String?
  afterUrl    String
  description String?
  missionId   String?  @unique
  mission     Mission? @relation(fields: [missionId], references: [id])
  createdAt   DateTime @default(now())
}

model Mission {
  id          String        @id @default(uuid())
  clientId    String
  client      User          @relation("ClientMissions", fields: [clientId], references: [id])
  proId       String
  pro         User          @relation("ProMissions", fields: [proId], references: [id])
  status      MissionStatus @default(PENDING)
  service     String
  description String?       @db.Text
  address     String
  scheduledAt DateTime?
  completedAt DateTime?
  agreedPrice Int?
  finalPrice  Int?
  clientRating Int?
  clientReview String?      @db.Text
  clientProof String?
  portfolioItem PortfolioItem?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  review      Review?
}

model Review {
  id         String   @id @default(uuid())
  missionId  String   @unique
  mission    Mission  @relation(fields: [missionId], references: [id])
  reviewerId String
  reviewer   User     @relation(fields: [reviewerId], references: [id])
  rating     Int
  comment    String?  @db.Text
  proofUrl   String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SenderMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content    String   @db.Text
  read       Boolean  @default(false)
  missionId  String?
  createdAt  DateTime @default(now())
}

model SavedPro {
  id        String   @id @default(uuid())
  clientId  String
  client    User     @relation("SavedPros", fields: [clientId], references: [id])
  proId     String
  pro       Profile  @relation(fields: [proId], references: [id])
  createdAt DateTime @default(now())

  @@unique([clientId, proId])
}

model ProfileView {
  id        String   @id @default(uuid())
  proId     String
  pro       Profile  @relation(fields: [proId], references: [id])
  viewerSession String?
  date      DateTime @default(now())
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
